#include <algorithm>
#include <map>
#include <set>
#include <string>
#include <cmath>
#include <queue>
#include <stack>
#include <deque>
 
using namespace std;
 
void solve() {
        long long n, k;
        cin >> n >> k;
 
        long long extra = n;
        long long cost = 1;
        long long ans = 0;
 
        while (extra >= cost) {
            long long buy = min(k, extra / cost);
            ans += buy;
            extra = extra - buy * cost;
            cost <<= 1;
        }
 
        cout << ans << endl;
}
 
int main() {
    int t;
    cin >> t;
    while (t--) solve();
    return 0;
}
