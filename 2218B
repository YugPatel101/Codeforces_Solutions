using namespace std;
 
void solve() {
    vector<int> a(7);
    for (int i = 0; i < 7; i++) cin >> a[i];
    sort(a.begin(), a.end());
    int sum=0;
 
    for(int i=0;i<7;i++){
        sum+= a[i];
    }
    sum = (-1) * (sum - (2*a[6]));
 
    cout << sum << endl;
}
 
int main() {
    int t;
    cin >> t;
    while (t--) solve();
    return 0;
}
