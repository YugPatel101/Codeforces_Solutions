#include <iostream>
#include <vector>
#include <algorithm>
#include <map>
#include <set>
#include <string>
#include <cmath>
#include <queue>
#include <stack>
#include <deque>

using namespace std;

void solve() {
    int n;cin >> n;
    bool allZeroes = true;
    int segment_count = 0;

    vector<long long> a(n);

    for (int i = 0; i < n; i++) {
        cin >> a[i];

        if (a[i] != 0) {
            allZeroes = false;

            if (i == 0 || a[i - 1] == 0) {
                segment_count++;
            }
        }
    }

    if (allZeroes) {
        cout << "0\n";
    }
    else {
        if (segment_count == 1) {
            cout << "1\n";
        }
        else {
            cout << "2\n";
        }
    }
}

int main() {
    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
