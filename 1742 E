#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;
 
int main() {
    int t;
    cin >> t;
    while (t--) {
        int n, q;
        cin >> n >> q;
 
        vector<long long> a(n);
        for (int i = 0; i < n; i++) {
            cin >> a[i];
        }
 
        vector<long long> prefMax(n), prefSum(n);
        prefMax[0] = a[0];
        prefSum[0] = a[0];
 
        for (int i = 1; i < n; i++) {
            prefMax[i] = max(prefMax[i - 1], a[i]);
            prefSum[i] = prefSum[i - 1] + a[i];
        }
 
        while (q--) {
            long long k;
            cin >> k;
 
            int idx = upper_bound(prefMax.begin(), prefMax.end(), k) - prefMax.begin() - 1; // evi pos return karse ke jya value will be greater than the k
 
            if (idx < 0)
                cout << 0 << " ";
            else
                cout << prefSum[idx] << " ";
        }
        cout << '\n';
    }
    return 0;
}
