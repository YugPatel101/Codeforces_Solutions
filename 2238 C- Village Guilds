#include <iostream>
#include <vector>
#include <algorithm>
#include <map>
#include <set>
#include <string>
#include <cmath>
#include <queue>
#include <stack>
#include <deque>
 
using namespace std;
 
#define int long long
 
void solve() {
    int n;
    cin >> n;
 
    vector<int> p(n + 1);
    vector<int> depth(n + 1, 0);
    vector<int> maxi;
 
    for (int i = 2; i <= n; i++) {
        cin >> p[i];
        depth[i] = depth[p[i]] + 1;
    }
 
    maxi = depth;
 
    for (int i = n; i >= 2; i--) {
        if (maxi[i] > maxi[p[i]]) {
            maxi[p[i]] = maxi[i];
        }
    }
 
    vector<int> highest(n + 1, -1);
    vector<int> sec_highest(n + 1, -1);
 
    for (int i = 2; i <= n; i++) {
        int child = maxi[i];
        int par = p[i];
 
        if (child > highest[par]) {
            sec_highest[par] = highest[par];
            highest[par] = child;
        }
        else if (child > sec_highest[par]) {
            sec_highest[par] = child;
        }
    }
 
    int ans = n;
 
    for (int i = 1; i <= n; i++) {
        if (sec_highest[i] > depth[i]) {
            ans += sec_highest[i] - depth[i];
        }
    }
 
    cout << ans << endl;
}
 
signed main() {
    int t;
    cin >> t;
 
    while (t--) {
        solve();
    }
 
    return 0;
}
