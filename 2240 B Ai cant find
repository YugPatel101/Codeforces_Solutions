using namespace std;
 
const long long MOD = 998244353;
 
long long power(long long a, long long b) {
    long long ans = 1;
    while (b > 0) {
        if (b & 1)
            ans = (ans * a) % MOD;
        a = (a * a) % MOD;
        b >>= 1;
    }
    return ans;
}
 
void solve() {
    long long n, m, r, c; cin >> n >> m >> r >> c;
 
    long long expo = (r - 1) * m + (c - 1) * n - (r - 1) * (c - 1);
    long long uttar =  power(2, expo);
    cout << uttar << endl;
}
 
int main() {
    int t;
    cin >> t;
    while (t--) solve();
    return 0;
}
