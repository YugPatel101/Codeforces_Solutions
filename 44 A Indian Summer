#include<bits/stdc++.h>
using namespace std;
typedef long long ll;
 
void solve(){
    int n; cin>>n;
    set<pair<string,string>> s;
    for(int i=0;i<n;i++){
        string a,b; cin>>a>>b;
        s.insert({a,b});
    }
    cout<<s.size()<<"\n";
}
 
int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int t=1;
    while(t--) solve();
}
