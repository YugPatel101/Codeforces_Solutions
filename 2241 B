using namespace std;
 
void solve() {
    long long x; cin >> x;
    int d = 0;
    long long t = x;
    while (t > 0) {
        d++;
        t /= 10;
    }
    long long y = 1;
    for (int i = 0; i < d; i++) y *= 10;
    y += 1;
    cout << y << endl;
}
 
int main() {
    int t;
    cin >> t;
    while (t--) solve();
    return 0;
}
