#include <iostream>
#include <vector>
#include <algorithm>
#include <map>
#include <set>
#include <string>
#include <cmath>
#include <queue>
#include <stack>
#include <deque>
 
using namespace std;
 
void solve() {
    int a, b, n;
    cin >> a >> b >> n;
 
    long long sum = b;
    vector<int> time(n);
 
    for (int i = 0; i < n; i++) {
        cin >> time[i];
    }
 
    for (int i = 0; i < n; i++) {
        if (time[i] < a - 1) {
            sum += time[i];
        }
        else {
            sum += a - 1;
        }
    }
 
    cout << sum << "\n";
}
 
int main() {
    int t;
    cin >> t;
 
    while (t--) {
        solve();
    }
 
    return 0;
}
