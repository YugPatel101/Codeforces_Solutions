#include <iostream>
#include <vector>
#include <algorithm>
#include <map>
#include <set>
#include <string>
#include <cmath>
#include <queue>
#include <stack>
#include <deque>
 
using namespace std;
 
void solve() {
    int n;
    cin >> n;
    vector<long long> a(n), b(n);
    for (auto &x : a) cin >> x; 
    for (auto &x : b) cin >> x;
 
    long long prefix = 0;
    bool ok = true;
    for (int i = 0; i < n; i++) {
        prefix += (b[i] - a[i]);
        if (prefix < 0) {
            ok = false;
        }
    }
 
    cout << (ok ? "YES" : "NO") << "\n";
}
 
int main() {
    int t;
    cin >> t;
    while (t--) solve();
    return 0;
}
