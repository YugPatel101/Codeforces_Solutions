using namespace std;
 
void solve() {
    int n;
    cin >> n;
    string s;
    cin >> s;
    int runs = 1;
    for (int i = 1; i < n; i++) {
        if (s[i] != s[i - 1]) runs++;
    }
    if (runs <= 1){
    cout << 1 << endl;
}
    else if (runs == 2) {
        cout << 2 << endl;
    }
    else cout << 1 << endl;
}
 
int main() {
    int t;
    cin >> t;
    while (t--) solve();
    return 0;
}
