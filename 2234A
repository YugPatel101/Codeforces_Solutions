#include <iostream>
#include <vector>
#include <algorithm>
#include <map>
#include <set>
#include <string>
#include <cmath>
#include <queue>
#include <stack>
#include <deque>
 
using namespace std;
 
void solve() {
    int n;
        cin >> n;
        vector<long long> b(n);
 
        for(int i = 0; i < n; i++) cin >> b[i];
 
        if(n == 2){
            long long x = max(b[0], b[1]);
            long long y = min(b[0], b[1]);
            cout << x << ' ' << y << endl;
            return;
        }
 
        sort(b.begin(), b.end(), greater<long long>());
 
        bool ok = true;
 
        for(int i = 1; i < n; i++) {
            if(b[i] >= b[i - 1]) {
                ok = false;
                break;
            }
        }
 
        for (int i = 0; ok && i + 2 < n; i++) {
            if(b[i] % b[i + 1] != b[i + 2]) {
                ok = false;
            }
        }
 
        if(ok){
            cout << b[0] << ' ' << b[1] << endl;
        }
        else{
            cout << -1 << endl;
        }
}
 
int main() {
    int t;
    cin >> t;
    while (t--) solve();
    return 0;
}
